{
  "info": {
    "name": "School Management APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Add School",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Example School\",\n  \"address\": \"123 School St, City, State\",\n  \"latitude\": 40.7128,\n  \"longitude\": -74.0060\n}"
        },
        "url": {
          "raw": "{{base_url}}/addSchool",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "addSchool"
          ]
        }
      }
    },
    {
      "name": "List Schools",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/listSchools?latitude=40.7128&longitude=-74.0060",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "listSchools"
          ],
          "query": [
            {
              "key": "latitude",
              "value": "40.7128"
            },
            {
              "key": "longitude",
              "value": "-74.0060"
            }
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "https://your-railway-app-name.up.railway.app"
    }
  ]
}